<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <application
        android:name=".SDKWrapperTester"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="false"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false"
        tools:ignore="DataExtractionRules">

        <activity
            android:name="com.governikus.ausweisapp.tester.MainActivity"
            android:exported="true"
            android:launchMode="singleInstance">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name="com.governikus.ausweisapp.tester.wrapper.card.ui.WorkflowActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false"
            android:launchMode="singleInstance"/>

        <activity
            android:name="com.governikus.ausweisapp.tester.sdk.TesterActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false">
        </activity>
        <activity
            android:name="com.governikus.ausweisapp.tester.sdk.WebsocketActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false">
        </activity>

    </application>

</manifest>
