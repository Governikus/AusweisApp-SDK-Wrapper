<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/scroll_view_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_section_issuer_information_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_issuer_information"
            android:textAppearance="?attr/idl_textAppearanceListTitle"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tv_certificate_issuer_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_issuer_name"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintTop_toBottomOf="@id/tv_section_issuer_information_title"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <TextView
            android:id="@+id/tv_certificate_issuer_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_section_issuer_information_title"
            tools:text="Example issuer"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_issuer_name"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_issuer_name_label, tv_certificate_issuer_name"/>

        <TextView
            android:id="@+id/tv_certificate_issuer_url_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_issuer_url"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_issuer_name"/>

        <TextView
            android:id="@+id/tv_certificate_issuer_url"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_issuer_name"
            tools:text="http://example.com"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_issuer_url"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_issuer_url_label, tv_certificate_issuer_url"/>

        <TextView
            android:id="@+id/tv_section_subject_information_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_default"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/certificate_subject_information"
            android:textAppearance="?attr/idl_textAppearanceListTitle"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_issuer_url"/>

        <TextView
            android:id="@+id/tv_certificate_purpose_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_purpose"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_section_subject_information_title"/>

        <TextView
            android:id="@+id/tv_certificate_purpose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_section_subject_information_title"
            tools:text="Reading example data"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_purpose"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_purpose_label, tv_certificate_purpose"/>

        <TextView
            android:id="@+id/tv_certificate_subject_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_subject_name"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_purpose"/>

        <TextView
            android:id="@+id/tv_certificate_subject_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_purpose"
            tools:text="Example subject"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_subject_name"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_subject_name_label, tv_certificate_subject_name"/>

        <TextView
            android:id="@+id/tv_certificate_subject_url_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_subject_url"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_subject_name"/>

        <TextView
            android:id="@+id/tv_certificate_subject_url"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_subject_name"
            tools:text="http://subject.example.com"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_subject_url"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_subject_url_label, tv_certificate_subject_url"/>

        <TextView
            android:id="@+id/tv_section_terms_of_usage_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_default"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/certificate_tou"
            android:textAppearance="?attr/idl_textAppearanceListTitle"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_subject_url"/>

        <TextView
            android:id="@+id/tv_certificate_tou"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_section_terms_of_usage_title"
            tools:text="Example Terms of Usage: don't do anything illegal with this."/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_tou"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_tou"/>

        <TextView
            android:id="@+id/tv_section_validity_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_default"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/certificate_validity"
            android:textAppearance="?attr/idl_textAppearanceListTitle"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_tou"/>

        <TextView
            android:id="@+id/tv_certificate_issue_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_issue_date"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_section_validity_title"/>

        <TextView
            android:id="@+id/tv_certificate_issue_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_section_validity_title"
            tools:text="01.01.1990"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_issue_date"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tv_certificate_issue_date_label, tv_certificate_issue_date"/>

        <TextView
            android:id="@+id/tv_certificate_expiration_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:text="@string/certificate_expiration_date"
            android:textAppearance="?attr/idl_textAppearanceListItemCaption"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_issue_date"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tv_certificate_expiration_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_default"
            android:textAppearance="?attr/idl_textAppearanceListItem"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintLeft_toRightOf="@id/barrier_label"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_issue_date"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="31.12.2030"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_label"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="end"
            app:constraint_referenced_ids="tv_certificate_issuer_name_label,tv_certificate_issuer_url_label,tv_certificate_purpose_label,tv_certificate_subject_name_label, tv_certificate_subject_url_label, tv_certificate_issue_date_label, tv_certificate_expiration_date_label"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
